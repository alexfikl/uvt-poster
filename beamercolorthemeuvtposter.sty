\def\fileversion{v0.3}
\def\filedate{2025/05/15}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeuvtposter}[\filedate \fileversion UVT Poster Color Theme]

% <<< colors

% NOTE: https://dci.uvt.ro/identitate-vizuala
\definecolor{UVTDarkBlue}{RGB}{3, 58, 137}
\definecolor{UVTSkyBlue}{RGB}{37, 136, 231}
\definecolor{UVTLightBlue}{RGB}{174, 217, 248}

\definecolor{UVTBlack}{RGB}{18, 18, 18}
\definecolor{UVTAccentWhite}{RGB}{252, 245, 247}
\definecolor{UVTWhite}{RGB}{255, 255, 255}

% NOTE: taken from the document itself
\definecolor{UVTPosterYellow}{RGB}{228, 172, 36}
% FIXME: the PPTX templates don't seem to use the UVTDarkBlue color for some reason
% \definecolor{UVTBeamerDarkBlue}{RGB}{3, 58, 137}
\definecolor{UVTPosterDarkBlue}{RGB}{0, 37, 97}
\definecolor{UVTPosterDarkGray}{RGB}{166, 166, 166}
\definecolor{UVTPosterLightGray}{RGB}{191, 191, 191}

% NOTE: a slightly darker yellow for use in the text
\colorlet{UVTTextYellow}{UVTPosterYellow!60!black}

% >>>

% <<< styles

\setbeamercolor{title}{fg=white, bg= , parent=normal text}
\setbeamercolor{titlelike}{fg= , bg= , parent=normal text}
\setbeamercolor{author}{use=normal text, bg= , parent=normal text}
\setbeamercolor{date}{use=normal text, bg= , parent=normal text}
\setbeamercolor{institute}{use=normal text, parent=normal text}

\setbeamercolor{section title}{fg=white, use=title}
\setbeamercolor{frametitle}{fg=UVTDarkBlue, use=titlelike}

\setbeamercolor{headline}{fg=white,bg=UVTDarkBlue}
\setbeamercolor{headline rule}{bg=UVTPosterYellow}

\setbeamercolor{url text}{fg=UVTDarkBlue}

\setbeamercolor{block title}{fg=UVTDarkBlue}
\setbeamercolor{alerted text}{fg=UVTTextYellow}
\setbeamercolor{example text}{fg=UVTLightBlue}

\setbeamercolor{enumerate item}{fg=UVTPosterYellow, parent=normal text}
\setbeamercolor{description item}{fg=UVTPosterYellow, parent=normal text}

\setbeamercolor{caption}{fg=UVTPosterDarkGray, parent=normal text}

