\def\fileversion{v0.3}
\def\filedate{2025/05/15}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeuvtposter}[\filedate \fileversion UVT Poster Theme]

% <<< options

\RequirePackage{ifthen}
\RequirePackage{kvoptions}
\SetupKeyvalOptions{
    family=uvtposter,
    prefix=uvtposter@
}

% enable Helvetica Now Display
\DeclareBoolOption[false]{helveticanow}
% select language for logos
\DeclareStringOption[english]{language}
% show a debug layout grid
\DeclareBoolOption[false]{showframe}
\DeclareBoolOption[false]{layoutgrid}

\ProcessOptionsBeamer
\DeclareDefaultOption{\PassOptionsToPackage{\CurrentOption}{beamerposter}}
\ProcessKeyvalOptions*

% >>>

% <<< packages

\RequirePackage{ifpdf}

% fancy graphics
\RequirePackage{beamerposter}
\RequirePackage{tikz}

% nicer command definitions
\RequirePackage{xparse}
% used in defining blocks
\RequirePackage{adjustbox}
\RequirePackage{colortbl}

\ifuvtposter@showframe
    \RequirePackage{showframe}
\fi

\ifuvtposter@layoutgrid
    \RequirePackage[
        grid,
        gridunit=cm,
        gridcolor=gray!70,
        subgridcolor=gray!70,
        texcoord]{eso-pic}
\fi

% remove navigation symbols
\beamertemplatenavigationsymbolsempty

% set colors
\usecolortheme{uvtposter}

\newif\iflandscape
\ifdimgreater{\paperwidth}{\paperheight}{%
    \landscapetrue
}{%
    \landscapefalse
}

% >>>

% <<< code listing

\RequirePackage{listings}

\lstset{
    basicstyle=\ttfamily\small,
    keywordstyle=\color{UVTDarkBlue}\bfseries,
    commentstyle=\color{UVTPosterDarkGray},
    stringstyle=\color{UVTPosterYellow!70!black},
    numbers=left,
    numberstyle=\tiny\color{UVTDarkBlue!50},
    numbersep=6pt,
    frame=single,
    rulecolor=\color{UVTDarkBlue!30},
    backgroundcolor=\color{UVTDarkBlue!5},
    showstringspaces=false,
    breaklines=true,
}

% >>>

% <<< commands

% left
\ProvideDocumentCommand \footerleft { m } {\def\uvtposter@footerleft{#1}}
\ProvideDocumentCommand \footerweb { m } {\def\uvtposter@footerleft{\href{#1}{#1}}}

% middle
\ProvideDocumentCommand \footermiddle { m } {\def\uvtposter@footermiddle{#1}}
\ProvideDocumentCommand \footerlocation { m } {\def\uvtposter@footermiddle{#1}}

% right
\ProvideDocumentCommand \footerright { m } {\def\uvtposter@footerright{#1}}
\ProvideDocumentCommand \footername { m } {\def\uvtposter@footerright{#1}}
\ProvideDocumentCommand \footeremail { m } {\def\uvtposter@footerright{\href{mailto:#1}{#1}}}

\ProvideDocumentCommand \headerlogo  { m } {\def\uvtposter@headerlogo{#1}}
\ProvideDocumentCommand \headeruniversity { m } {\def\uvtposter@headeruniversity{#1}}
\ProvideDocumentCommand \headerdepartment { m } {\def\uvtposter@headerdepartment{#1}}
\ProvideDocumentCommand \headerconference { m } {\def\uvtposter@headerconference{#1}}

\ProvideDocumentCommand \heading { m } {%
    {\usebeamerfont{heading}\usebeamercolor[fg]{heading}#1}\strut\par}

\ProvideDocumentCommand \separatorcolumn {} {%
    \begin{column}{0.025\paperwidth}%
        \begin{center}%
            \textcolor{UVTPosterLightGray}{
                \rule{\uvtposter@separatorwidth}
                     {\dimexpr\paperheight-\uvtposter@headerheight-\uvtposter@titlebarheight-0.06\uvtposter@unitlength}}%
        \end{center}%
    \end{column}%
}

% >>>

% <<< assets

\ifthenelse{\equal{\uvtposter@language}{english}}{
    \headeruniversity{West University of Timișoara}
    \headerdepartment{Falculty Name \enspace·\enspace Department Name}
    \headerconference{Conference Name (2026)}
}{
\ifthenelse{\equal{\uvtposter@language}{romanian}}{
    \headeruniversity{Universitatea de Vest din Timișoara}
    \headerdepartment{Facultate \enspace·\enspace Departament}
    \headerconference{Numele Conferinței (2026)}
}{
    \PackageError{beamerthemeuvtposter}{Unknown language `\uvtposter@language`}{}
}}

\headerlogo{assets/logo-uvt-white.png}

% >>>

% <<< fonts

\ifpdftex
    \RequirePackage[utf8]{inputenc}
    \RequirePackage[T1]{fontenc}
\else
    \RequirePackage{fontspec}
\fi

\ifuvtposter@helveticanow
    \ifpdftex
        \PackageWarning{beamerthemeuvtposter}{HelveticaNowDisplay font is not available on pdfLaTeX. Remove the 'helveticanow' option to silence this warning or switch to LuaLaTeX / XeLaTex.}
        \RequirePackage[scale=0.9]{tgheros}
    \else
        \IfFontExistsTF{HelveticaNowDisplay}{
            \setsansfont[Ligatures=TeX]{HelveticaNowDisplay}
        }{
            \PackageWarning{beamerthemeuvtposter}{HelveticaNowDisplay font is not available on your system. Remove the 'helveticanow' option to silence this warning.}
            \setsansfont[Scale=0.9]{TeX Gyre Heros}}
    \fi
\else
    \ifpdftex
        \RequirePackage[scale=0.9]{tgheros}
    \else
        \setsansfont[Scale=0.9]{TeX Gyre Heros}
    \fi
\fi
\renewcommand{\familydefault}{\sfdefault}

\setbeamerfont{title}{size=\LARGE, series=\bfseries}
\setbeamerfont*{subtitle}{size=\large, series=\mdseries}
\setbeamerfont{author}{size=\normalsize, series=\bfseries}
\setbeamerfont{date}{size=\small, series=\mdseries}

\iflandscape
\setbeamerfont{headline title}{size=\Huge,series=\bfseries}
\setbeamerfont{headline author}{size=\Large, series=\bfseries}
\setbeamerfont{headline institute}{size=\normalsize}
\else
\setbeamerfont{headline title}{size=\Huge,series=\bfseries}
\setbeamerfont{headline author}{size=\Large, series=\bfseries}
\setbeamerfont{headline institute}{size=\Large}
\fi
\setbeamerfont{footline}{size=\Large,series=\bfseries}

\setbeamerfont*{heading}{size=\normalsize, series=\bfseries}

\setbeamerfont{alerted text} {size=\normalsize,series=\bfseries}
\setbeamerfont{block title}{size=\Large,series=\bfseries}
\setbeamerfont{block title alerted}{size=\Large,series=\bfseries}
\setbeamerfont{block title example}{size=\Large,series=\bfseries}
\setbeamerfont{theorem title}{size=\normalsize,series=\bfseries}

\setbeamerfont{page number in head/foot}{size=\tiny, series=\bfseries}
\setbeamerfont{url text}{size=\scriptsize,series=\bfseries}
\setbeamerfont{author in head/foot}{size=\scriptsize,series=\bfseries}

\setbeamerfont{itemize/enumerate body}{size=\normalsize}
\setbeamerfont{itemize/enumerate subbody}{size=\normalsize}
\setbeamerfont{itemize/enumerate subsubbody}{size=\normalsize}

\setbeamerfont{enumerate item}{size=\normalsize, series=\bfseries}
\setbeamerfont{description item}{size=\normalsize, series=\bfseries}

\setbeamerfont{bibliography item}{series=\bfseries}

% >>>

% <<< lengths

\newlength{\uvtposter@unitlength}
\iflandscape
    \setlength{\uvtposter@unitlength}{\paperwidth}
\else
    \setlength{\uvtposter@unitlength}{\paperheight}
\fi

\newlength{\uvtposter@headerheight}
\setlength{\uvtposter@headerheight}{0.0525\uvtposter@unitlength}
\newlength{\uvtposter@headerlogooffset}
\setlength{\uvtposter@headerlogooffset}{0.013\uvtposter@unitlength}
\newlength{\uvtposter@headerdothskip}
\setlength{\uvtposter@headerdothskip}{0.015\uvtposter@unitlength}
\newlength{\uvtposter@headerdotvskip}
\setlength{\uvtposter@headerdotvskip}{0.01\uvtposter@unitlength}

\newlength{\uvtposter@titlebarheight}
\iflandscape
\setlength{\uvtposter@titlebarheight}{0.075\uvtposter@unitlength}
\else
\setlength{\uvtposter@titlebarheight}{0.095\uvtposter@unitlength}
\fi
\newlength{\uvtposter@titlemarginwidth}
\setlength{\uvtposter@titlemarginwidth}{0.007\uvtposter@unitlength}

\newlength{\uvtposter@separatorwidth}
\setlength{\uvtposter@separatorwidth}{0.003\uvtposter@unitlength}

\newlength{\uvtposter@blockpadding}
\setlength{\uvtposter@blockpadding}{0.007\uvtposter@unitlength}

% >>>

% <<< outer: header / footer

% headline
\setbeamertemplate{headline}{
    \begin{beamercolorbox}[wd=\paperwidth, ht=\uvtposter@headerheight, dp=0pt]{headline}
        \vfill
        \hspace{\uvtposter@headerlogooffset} \includegraphics[height=\uvtposter@headerheight]{\uvtposter@headerlogo}
        \vfill
    \end{beamercolorbox}

    \begin{tikzpicture}[remember picture, overlay]
        \useasboundingbox (0, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);
        \usebeamercolor{title}

        % draw logo separator
        \draw[white, line width=\uvtposter@separatorwidth, opacity=0.5]
            ([xshift=1.5\uvtposter@headerheight, yshift=-0.8\uvtposter@headerheight]current page.north west)
            --
            ([xshift=1.5\uvtposter@headerheight, yshift=-0.2\uvtposter@headerheight]current page.north west);

        % university + department
        \node[
            anchor=west,
            xshift=1.75\uvtposter@headerheight,
            yshift=-0.5\uvtposter@headerheight
        ] at (current page.north west) {%
            \begin{minipage}{0.45\paperwidth}
                {\usebeamercolor{title} \usebeamerfont{title}
                \MakeUppercase{\uvtposter@headeruniversity}\strut\par}
                {\usebeamercolor{title} \usebeamerfont{subtitle}
                \MakeUppercase{\uvtposter@headerdepartment}\strut\par}
            \end{minipage}%
        };

        % dotted pattern on the right
        \foreach \x in {-1,...,30}{%
            \foreach \y in {0,...,5}{%
                \fill[white, opacity=0.1]
                    ([xshift=-(\x-2)*\uvtposter@headerdothskip,
                      yshift=-(\y-0.4)*\uvtposter@headerdotvskip]current page.north east)
                    circle (1ex);
            }%
        }%

        % presented at text
        \node[
            anchor=east,
            xshift=-0.5\uvtposter@headerheight,
            yshift=-0.5\uvtposter@headerheight
        ] at (current page.north east) {%
            \begin{minipage}[t]{0.45\paperwidth}
                \raggedleft
                {\usebeamercolor{title} \usebeamerfont{subtitle}
                 \MakeUppercase{Presented at}\strut\par}
                {\usebeamercolor{title} \usebeamerfont{title}
                 \uvtposter@headerconference\strut\par}
            \end{minipage}%
        };
    \end{tikzpicture}

    % title
    \iflandscape
    \begin{tikzpicture}
        \useasboundingbox (0, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);
        \usebeamercolor{title}

        % background
        \fill[bg] (0, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);
        \draw[fg, line width=\uvtposter@separatorwidth] (0, 0) -- (\paperwidth, 0);
        \fill[fg] (0, 0) rectangle (\uvtposter@titlemarginwidth, \uvtposter@titlebarheight);
        \fill[fg] (\paperwidth-\uvtposter@titlemarginwidth, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);

        % left side: title
        \node[anchor=west, fg] at (0.025\paperwidth, 0.5\uvtposter@titlebarheight) {%
            \begin{minipage}{0.5\paperwidth}
                {\usebeamerfont{headline title} \MakeUppercase{\inserttitle}}%
            \end{minipage}%
        };
        % separator
        \node[anchor=center] at (0.65\paperwidth, 0.5\uvtposter@titlebarheight) {%
            {\color{UVTPosterLightGray} \rule{\uvtposter@separatorwidth}{0.65\uvtposter@titlebarheight}}%
        };

        % right side: author + affiliation
        \node[anchor=east, fg] at (0.965\paperwidth, 0.5\uvtposter@titlebarheight) {%
            \begin{minipage}{0.35\paperwidth}
                \raggedleft
                {\usebeamerfont{headline author}\insertauthor\strut\par}%
                {\usebeamerfont{headline institute}\insertinstitute}%
            \end{minipage}%
        };
    \end{tikzpicture}
    \else
    \begin{tikzpicture}
        \useasboundingbox (0, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);
        \usebeamercolor{title}

        % background
        \fill[bg] (0, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);
        \draw[fg, line width=\uvtposter@separatorwidth] (0, 0) -- (\paperwidth, 0);
        \fill[fg] (0, 0) rectangle (\uvtposter@titlemarginwidth, \uvtposter@titlebarheight);
        \fill[fg] (\paperwidth-\uvtposter@titlemarginwidth, 0) rectangle (\paperwidth, \uvtposter@titlebarheight);

        % title
        \node[anchor=west, fg] at (0.025\paperwidth, 0.5\uvtposter@titlebarheight) {%
            \begin{minipage}{\paperwidth}
                {\usebeamerfont{headline title} \MakeUppercase{\inserttitle}\strut\par}%
                \vspace*{5ex}
                {\usebeamerfont{headline author}\insertauthor\enspace·\enspace}%
                {\usebeamerfont{headline institute}\insertinstitute}%
            \end{minipage}%
        };
    \end{tikzpicture}
    \fi
}

% footline

\setbeamertemplate{footline}{
    \begin{beamercolorbox}[vmode]{headline}
        \usebeamerfont{footline}
        \centering
        \vspace{2ex}
        \hspace{0.025\paperwidth}
        \@ifundefined{uvtposter@footerleft}{}{\uvtposter@footerleft}
        \hfill
        \@ifundefined{uvtposter@footermiddle}{}{\uvtposter@footermiddle}
        \hfill
        \@ifundefined{uvtposter@footerright}{}{\uvtposter@footerright}
        \hspace{0.025\paperwidth}
        \vspace{1.75ex}
    \end{beamercolorbox}
}

% >>>

% <<< inner

% <<< itemize

\setbeamertemplate{itemize item}{
    \tikz[baseline=-0.65ex]{
        % circle
        \node[
        circle,
        minimum size=1ex,
        inner sep=0pt,
        draw=UVTDarkBlue
        ] (c) {};
    }
}

\setbeamertemplate{itemize subitem}{\color{UVTDarkBlue}\small $\bullet$}
\setbeamertemplate{itemize subsubitem}{\color{UVTSkyBlue}\small $\bullet$}

% >>>

% <<< blocks

\NewDocumentCommand \uvtposter@block {m} {
    \begin{beamercolorbox}{#1 title}
        \usebeamerfont*{#1 title}
        \vbox{}\vskip 0.2ex
        \MakeUppercase{\insertblocktitle}\par
        \vskip 1ex
        {\usebeamercolor{#1 title} \color{fg} \hrule height \uvtposter@separatorwidth}
        \vskip 1ex
    \end{beamercolorbox}
    \usebeamerfont*{#1 text}
}

\setbeamertemplate{block begin}{\uvtposter@block{block}}
\setbeamertemplate{block end}{\vspace{\uvtposter@blockpadding}}

\setbeamertemplate{block alerted begin}{\uvtposter@block{block alerted}}
\setbeamertemplate{block alerted end}{\vspace{\uvtposter@blockpadding}}

\setbeamertemplate{block example begin}{\uvtposter@block{block example}}
\setbeamertemplate{block example end}{\vspace{\uvtposter@blockpadding}}

% >>>

% <<< figures

% disable "Figure:" in the captions
\setbeamertemplate{caption}{\scriptsize\insertcaption}
\setbeamertemplate{caption label separator}{}

% >>>

% <<< quote

\renewenvironment{quote}{%
    \vspace{1ex}
    \begin{tabular}{!{\color{UVTPosterDarkGray}{\vrule width 4pt}}%
                    >{\columncolor{UVTAccentWhite}}m{0.98\linewidth}}%
        \vspace{0.75ex}\itshape
}{%
        \vspace{0.5ex}
    \end{tabular}%
    \vspace{0ex}
}

% >>>

% <<< theorem

\setbeamertemplate{theorem begin}{%
    \vspace{1ex}%
    \begin{tabular}{!{\color{UVTPosterDarkBlue}{\vrule width 4pt}}%
                    >{\columncolor{UVTLightBlue!10}}m{0.98\linewidth}}%
        \vspace{0.75ex}%
        {\usebeamerfont{theorem title}\inserttheoremname%
        \ifx\inserttheoremaddition\empty\else\ (\inserttheoremaddition)\fi}%
        \par\smallskip
}
\setbeamertemplate{theorem end}{%
        \vspace{0.5ex}
    \end{tabular}%
    \vspace{0ex}
}

% >>>

% <<< bibliography

\setbeamertemplate{bibliography item}{\insertbiblabel}

% >>>

\setbeamersize{description width=8ex}

